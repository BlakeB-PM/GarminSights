# ============================================
# GarminSights Project .gitignore
# ============================================

# ============================================
# Node.js / Next.js
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next.js
.next/
out/
build/
dist/
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ============================================
# Python
# ============================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
# Allow the frontend source lib directory (excluded by the Python lib/ rule above)
!frontend/src/lib/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/
.ENV/
.env/

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb_checkpoints/

# pyenv
.python-version

# ============================================
# Environment & Configuration Files
# ============================================
# Environment variables
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Garmin Connect Configuration (keep .example, ignore actual config)
GarminConnectConfig.json
**/GarminConnectConfig.json
!**/GarminConnectConfig.json.example
*.conf
my-defines.mk

# ============================================
# Database Files
# ============================================
# SQLite databases
*.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Specific database files
garmin/garmin.db
garmin/*.db
garmin/*.sqlite
garmin/*.sqlite3

# ============================================
# Log Files
# ============================================
*.log
*.log.*
logs/
garmin/garmindb.log
garmin/*.log

# ============================================
# Garmin Data Files (Large binary files)
# ============================================
# FIT files (activity data)
*.fit
*.FIT

# TCX files (GPS data)
*.tcx
*.TCX

# ============================================
# Build & Temporary Files
# ============================================
# Python
*.pyc
*.pyo
*.pyd
*.sublime-project
*.sublime-workspace

# Compiled files
*.class
*.dll
*.exe
*.o
*.so

# Archives
*.zip
*.tar
*.tar.gz
*.rar

# ============================================
# IDE & Editor Files
# ============================================
# VSCode
.vscode/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# IntelliJ / PyCharm
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ============================================
# OS-Specific Files
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

# ============================================
# Project-Specific Files
# ============================================
# Test files
test/test_files/
test/*.txt
bugreport.txt
*stats.txt

# Screenshots (optional - uncomment if you don't want to commit screenshots)
# garmin/Screenshots/
# *.jpg
# *.jpeg
# *.png

# Jupyter checkpoints
garmin/Jupyter/.ipynb_checkpoints/

# Session files
garth_session
*.session

# Temporary files
tmp/
temp/
*.tmp
*.temp

# ============================================
# Package Manager Files (Optional)
# ============================================
# Uncomment if you want to ignore lock files
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# poetry.lock
# Pipfile.lock

# ============================================
# Miscellaneous
# ============================================
# Python
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Project specific ignores from subdirectories
pyproject.toml
uv.lock

