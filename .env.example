# ============================================
# GarminSights Environment Variables
# Copy this file to .env and fill in your values.
# ============================================

# ── Garmin Connect credentials ───────────────
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password

# ── Anthropic API (AI Coach) ─────────────────
# In production (fly.io), set this as a secret: fly secrets set ANTHROPIC_API_KEY=sk-ant-...
# For local development only:
# ANTHROPIC_API_KEY=sk-ant-...

# ── App Security ─────────────────────────────
# Required for production. Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# When set, all API requests must include: Authorization: Bearer <this-value>
APP_SECRET_KEY=

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins.
# For Cloud Run with the frontend served from the same container, leave empty.
# For separate frontend deployments, set to the frontend URL.
# CORS_ORIGINS=https://your-domain.com

# ── Database ─────────────────────────────────
# Path to SQLite database file. In Docker, use a volume-mounted path.
# DATABASE_PATH=/data/fitness.db

# ── Environment ──────────────────────────────
# Set to "production" to disable Swagger docs and enable security features.
# ENV=production
