# GarminSights Database Configuration
# Copy this file to .env.local and update with your actual values

# Optional: Path to your GarminDB SQLite database
# If not set, the app will auto-detect the database location:
# - First checks: garmin/garmin_activities.db (relative to project root)
# - Then checks: ~/HealthData/DBs/garmin_activities.db (default GarminDB location)
# Example: DATABASE_PATH=C:/Users/YourName/HealthData/DBs/garmin_activities.db
# DATABASE_PATH=
